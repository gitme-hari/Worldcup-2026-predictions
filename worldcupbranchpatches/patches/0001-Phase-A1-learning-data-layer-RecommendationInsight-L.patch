@@ -0,0 +1,18 @@
+-- Phase A1: store one row per meaningful recommendation event per fixture.
+-- Used by learning-repository.ts to build RecommendationInsight changelog and
+-- to answer "what changed since yesterday" queries in the Matches page.
+
+CREATE TABLE IF NOT EXISTS recommendation_snapshots (
+  id            uuid PRIMARY KEY DEFAULT gen_random_uuid(),
+  fixture_id    text NOT NULL,
+  event         text NOT NULL,       -- 'created' | 'learning_applied' | 'api_context_updated' | 'scoreline_changed' | 'locked'
+  scoreline_h   smallint NOT NULL,
+  scoreline_a   smallint NOT NULL,
+  confidence    text NOT NULL,       -- 'High' | 'Medium' | 'Low'
+  insight       jsonb NOT NULL,      -- full RecommendationInsight snapshot
+  driver        text,                -- plain-English cause e.g. "Defensive momentum signal (Strong)"
+  created_at    timestamptz NOT NULL DEFAULT now()
+);
+
+CREATE INDEX IF NOT EXISTS recommendation_snapshots_fixture_time
+  ON recommendation_snapshots (fixture_id, created_at DESC);
diff --git a/worldcup-app/supabase/migrations/005_match_reviews.sql b/worldcup-app/supabase/migrations/005_match_reviews.sql
new file mode 100644
index 0000000..b7bed6c
--- /dev/null
+++ b/worldcup-app/supabase/migrations/005_match_reviews.sql
@@ -0,0 +1,23 @@
+-- Phase A1: one row per completed fixture, auto-generated by the learning engine.
+-- Source of truth for Decision Review (Tab 1) and Engine Learning (Tab 2)
+-- on the Performance page. Learning signals are derived from this table at read time.
+
+CREATE TABLE IF NOT EXISTS match_reviews (
+  fixture_id       text PRIMARY KEY,
+  engine_h         smallint,          -- pool recommendation home goals (null if no rec stored)
+  engine_a         smallint,
+  my_h             smallint NOT NULL,
+  my_a             smallint NOT NULL,
+  actual_h         smallint NOT NULL,
+  actual_a         smallint NOT NULL,
+  my_pts           smallint NOT NULL, -- pool points earned (4/2/1/0)
+  engine_pts       smallint,          -- points the rec would have earned (null if no rec)
+  overridden       boolean NOT NULL DEFAULT false,
+  override_reason  text,
+  evidence         jsonb,             -- string[] of context bullets
+  impact_verdict   text NOT NULL,     -- 'Override succeeded' | 'Override failed' | 'Both matched' | 'Both missed' | 'Accepted rec'
+  lesson           text NOT NULL,     -- one-sentence learning
+  blind_spot       text,              -- BlindSpotCategory if engine failed
+  engine_version   text NOT NULL DEFAULT '1.0',
+  created_at       timestamptz NOT NULL DEFAULT now()
+);
